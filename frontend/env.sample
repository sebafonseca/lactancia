# API backend (opcional en desarrollo)
# VITE_API_URL=http://localhost:5000

# Cal.com — URLs públicas de cada tipo de evento (copiar desde el dashboard de Cal.com)
# Sin estas variables, Cal.com se omite y se abre WhatsApp para coordinar la misma modalidad.
VITE_CAL_COM_PRESENCIAL_URL=
VITE_CAL_COM_ONLINE_URL=

# Opcional — si más adelante agendás talleres o puerperio en Cal.com
# VITE_CAL_COM_TALLERES_URL=
# VITE_CAL_COM_CUIDADOS_URL=
